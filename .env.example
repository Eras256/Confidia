# ============================================================
# Confidia — Environment Variables
# Copy this file to .env and fill in real values for production.
# For local development, the defaults (fallbacks) are used.
# ============================================================

# ── API Server ───────────────────────────────────────────────
# JWT secret used to sign session tokens issued by /auth/verify
JWT_SECRET=your_jwt_secret_here

# Stellar secret key for the SEP-10 web authentication server.
# If not set, a random ephemeral keypair is generated on startup.
SEP10_SERVER_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Private signing key for the Stellar agentic payment client.
# If not set, a mock key is used in development mode.
AGENT_SIGNING_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Set to "production" to disable mock/test mode in LCP and Agent clients.
NODE_ENV=development

# ── Frontend (Next.js) ──────────────────────────────────────
# Base URL of the Confidia API server
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Stellar Network ─────────────────────────────────────────
# STELLAR_NETWORK=testnet
# STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
