# ============================================================
# Confidia — Environment Variables
# Copy this file to .env and fill in real values for production.
# For local development, the defaults (fallbacks) are used.
#
# ⚠️ SECRETS: The placeholders below are DEV MOCKS. `NODE_ENV=development`
# enables mock/test mode and permits ephemeral fallbacks. In production
# (`NODE_ENV=production`), every secret MUST be supplied from a real secrets
# manager and rotated on a schedule:
#   - JWT_SECRET, SEP10_SERVER_SECRET, AGENT_SIGNING_KEY, STELLAR_WALLET_SECRET
#     → injected via the platform secret store (e.g. Fly.io secrets / Vault /
#       cloud KMS), never committed. Rotate SEP-10 and agent signing keys
#       periodically; the app reads them only from process.env.
# `.env` and `.env.local` are git-ignored and never published.
# ============================================================

# ── API Server ───────────────────────────────────────────────
# JWT secret used to sign session tokens issued by /auth/verify
JWT_SECRET=your_jwt_secret_here

# Stellar secret key for the SEP-10 web authentication server.
# If not set, a random ephemeral keypair is generated on startup.
SEP10_SERVER_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Private signing key for the Stellar agentic payment client.
# If not set, a mock key is used in development mode.
AGENT_SIGNING_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Set to "production" to disable mock/test mode in LCP and Agent clients.
NODE_ENV=development

# ── Frontend (Next.js) ──────────────────────────────────────
# Base URL of the Confidia API server
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Stellar Network ─────────────────────────────────────────
# STELLAR_NETWORK=testnet
# STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# ── Supabase (real Postgres persistence for the API) ────────
# Server-only — read exclusively by apps/api. NEVER prefix with NEXT_PUBLIC_
# and never use the service role key client-side: it bypasses Row Level
# Security entirely. If unset, the API falls back to the file-backed
# MockSupabaseClient (db.json) so `pnpm dev` still works with zero setup.
# Set real values with `fly secrets set` on Fly.io — never commit them.
# Schema: run `SUPABASE_DB_URL="postgresql://..." node scripts/db/migrate.js`
# once against your project's Postgres connection string (Settings > Database).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
