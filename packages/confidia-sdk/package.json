{
  "name": "confidia-sdk",
  "version": "1.0.0",
  "main": "./dist/cjs/src/index.js",
  "module": "./dist/esm/src/index.js",
  "types": "./dist/esm/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/src/index.d.ts",
      "import": "./dist/esm/src/index.js",
      "require": "./dist/cjs/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json",
    "test": "vitest run"
  }
,
  "dependencies": {
    "confidia-config": "workspace:^1.0.0"
  },
  "devDependencies": {
    "confidia-test-utils": "workspace:^1.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
